function longestSubstringReplacement(str, k) {
  // Step 1: Know what you are storing
  let windowStart = 0;
  let freq = new Map();
  let best = 0;
  let maxFreq = 0;

  // Step 2: Expand the window with windowEnd

  //At each step: Take str[windowEnd] add it to the frequency map update maxFreq

  for (let windowEnd = 0; windowEnd < str.length; windowEnd++) {
    let ch = str[windowEnd];
    freq.set(ch, (freq.get(ch) ?? 0) + 1);

    maxFreq = Math.max(maxFreq, freq.get(ch));

    // Step 3: Write the formula for when the window is invalid

    while (windowEnd - windowStart + 1 - maxFreq > k) {
      //Step 4: Shrink from the left if invalid

      let ch = str[windowStart];
      freq.set(ch, freq.get(ch) - 1);
      windowStart++;
    }

    best = Math.max(windowEnd - windowStart + 1, best);
  }

  return best;
}

console.log(longestSubstringReplacement("AABABBA", 1));
