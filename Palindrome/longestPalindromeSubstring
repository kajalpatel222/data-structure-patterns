function longestPalindromeSubstring(str) {
  if (str.length < 2) return str;

  // Step 2: Keep track of best palindrome seen so far

  let bestStart = 0,
    bestLength = 0;

  //Step 3: Create a helper that expands from the center

  function expandFRomCenter(left, right) {
    while (left >= 0 && right < str.length && str[left] == str[right]) {
      left--;
      right++;
    }

    //Step 4: After expansion stops, calculate the actual palindrome

    left = left + 1;
    right = right - 1;

    // Step 5: Update best answer if current one is longer

    let currentLength = right - left + 1;

    if (currentLength > bestLength) {
      bestLength = currentLength;
      bestStart = left;
    }
  }

  // Step 6: Loop through every index and treat it as a center

  for (let i = 0; i < str.length; i++) {
    expandFRomCenter(i, i);
    expandFRomCenter(i, i + 1);
  }

  //Step 7: Return the best substring

  return str.slice(bestStart, bestStart + bestLength);
}

