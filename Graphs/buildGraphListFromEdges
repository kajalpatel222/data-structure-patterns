function getGraphAdjacencyList(edges){
         
         const graphList = {}
     
         for(let [a,b] of edges){
             if(!graphList[a]) graphList[a] = new Array();
             if(!graphList[b]) graphList[b] = new Array();
             
             graphList[a].push(b)
             graphList[b].push(a)
         }
     
        return graphList
         
     }

let edges = [[0,1],[4,5],[2,4],[1,3],[0,2]];

console.log(getGraphAdjacencyList(edges))
