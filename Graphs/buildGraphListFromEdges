function buildGraphListFromEdges(edges, num) {
    
    let graphList = {};
    
    for(let i=0; i<num; i++){
        graphList[i] = new Array();
    }
    
    
   for(let [a,b] of edges){
       graphList[a].push(b);
       graphList[b].push(a)
   }
   
   return graphList
   
    
}

let num = 6;
let edges = [[0,1],[4,5],[2,4],[1,3],[0,2]];

console.log(buildGraphListFromEdges(edges, num))
