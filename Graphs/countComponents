// Count Connected Components in an Undirected Graph
// -------------------------------------------------
// A connected component is a group of nodes where each node
// can reach every other node in that group.
//
// Approach:
// 1. Convert the edge list into an adjacency list using a Map.
// 2. Use DFS to explore all nodes in one connected component.
// 3. Loop through all nodes in the graph.
// 4. Every time we find an unvisited node, start a DFS from it
//    and increment the component count.

function graphCountConnectedComponents(n, edges) {
  // Build adjacency list from edges
  function buildGraph(edges) {
    const graph = new Map();

    for (const [a, b] of edges) {
      // Create empty neighbor list if node is seen for the first time
      if (!graph.has(a)) graph.set(a, []);
      if (!graph.has(b)) graph.set(b, []);

      // Since this is an undirected graph,
      // add connection in both directions
      graph.get(a).push(b);
      graph.get(b).push(a);
    }

    return graph;
  }

  const visited = new Set();
  let groupCount = 0;
  const graph = buildGraph(edges);

  // DFS explores one full connected component
  function dfs(node) {
    if (visited.has(node)) return;

    visited.add(node);

    for (const neighbor of graph.get(node)) {
      dfs(neighbor);
    }
  }

  // Go through every node in the graph.
  // If the node has not been visited yet,
  // it means we found a new connected component.
  for (const node of graph.keys()) {
    if (!visited.has(node)) {
      dfs(node);
      groupCount++;
    }
  }

  return groupCount;
}


// Example
console.log(
  graphCountConnectedComponents(6, [[0, 1], [4, 5], [2, 4], [1, 3], [0, 2]])
); // 1
