export default function findInRotatedArray(numbers, target) {
  if (numbers.length == 0) {
    return -1;
  }
  function pivot(numbers) {
    let left = 0,
      right = numbers.length - 1;

    while (left < right) {
      let mid = Math.floor((left + right) / 2);
      if (numbers[mid] > numbers[right]) {
        left = mid + 1;
      } else {
        right = mid;
      }
    }
    return left;
  }

  function binarySearch(low, high, numbers, target) {
    while (low <= high) {
      let mid = Math.floor((low + high) / 2);

      if (numbers[mid] == target) {
        return mid;
      } else if (numbers[mid] > target) {
        high = mid - 1;
      } else {
        low = mid + 1;
      }
    }

    return -1;
  }

  let piv = pivot(numbers);
  console.log("pivot", piv);

  if (target >= numbers[piv] && target <= numbers[numbers.length - 1]) {
    console.log("here");
    return binarySearch(piv, numbers.length - 1, numbers, target);
  } else {
    console.log("there");

    return binarySearch(0, piv - 1, numbers, target);
  }

  console.log(pivot(numbers));
}
