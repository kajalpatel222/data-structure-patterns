function smallestInRotatedArray(numbers) {
  if (numbers.length === 0) return -1; // or throw error depending on your preference

  let left = 0;
  let right = numbers.length - 1;

  while (left < right) {
    const mid = Math.floor((left + right) / 2);

    if (numbers[mid] > numbers[numbers.length - 1]) {
      left = mid + 1;
    } else {
      right = mid;
    }
  }

  return numbers[left];
}

console.log(smallestInRotatedArray([4, 5, 6, 7, 0, 1, 2])); // 0
